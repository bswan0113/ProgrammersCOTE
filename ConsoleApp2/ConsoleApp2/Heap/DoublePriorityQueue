import java.util.PriorityQueue;

class Solution {
    public int[] solution(String[] operations) {
        int[] answer = {};
        PriorityQueue<Integer> minQueue = new PriorityQueue<>();
        PriorityQueue<Integer> maxQueue = new PriorityQueue<>((x, y) -> y - x);
        
        for(int i = 0; i < operations.length; i++){
            String operation = operations[i];
            if(operation.startsWith("I")){
                int num = Integer.parseInt(operation.substring(2));
                minQueue.offer(num);
                maxQueue.offer(num);
            } 
            else if(operation.equals("D 1")){
                if(maxQueue.size() > 0){
                    int num = maxQueue.poll();
                    minQueue.remove(num);
                }
            }
            else if(operation.equals("D -1")){
                if(minQueue.size() > 0){
                    int num = minQueue.poll();
                    maxQueue.remove(num);
                }
            }
        }

        int max = maxQueue.size() > 0 ? maxQueue.poll() : 0;
        int min = minQueue.size() > 0 ? minQueue.poll() : 0;
        answer = new int[]{max, min};
        return answer;
    }
}